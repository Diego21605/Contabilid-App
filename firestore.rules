rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permitir acceso completo al documento del usuario
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Permitir acceso completo a cualquier subcolección y documento dentro del usuario
    match /usuarios/{userId}/{collectionId}/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Compatibilidad para la colección /users si se requiere
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/{collectionId}/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
